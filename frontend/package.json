{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently --kill-others \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "cd ../backend && uv run uvicorn app.main:app --reload",
    "dev:frontend": "vite",
    "build": "tsc -b && vite build",
    "build-app": "tsc -b && vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate": "orval"
  },
  "build": {
    "appId": "com.wallpaper-vault.app",
    "productName": "Wallpaper Vault",
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!**/.venv",
          "!**/.ruff_cache",
          "!**/.python-version"
        ]
      },
      {
        "from": "../db",
        "to": "db"
      },
      {
        "from": "public",
        "to": "public"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "public/favicon.svg"
    }
  },
  "dependencies": {
    "@mantine/core": "^7.17.1",
    "@mantine/form": "^7.17.1",
    "@mantine/hooks": "^7.17.1",
    "@mantine/notifications": "^7.17.1",
    "@tabler/icons-react": "^3.31.0",
    "@tanstack/react-query": "^5.67.2",
    "axios": "^1.8.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "orval": "^7.6.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "overrides": {
    "esbuild": "^0.27.0"
  }
}
